{
  "schemaVersion": "1.0.0",
  "id": "scientific_workbench",
  "label": "Load-Pulling Quadruped Scientific Workbench",
  "layoutProfileId": "scientific_workbench",
  "centralViews": ["branch_state", "hildebrand_footfall", "run_overlay"],
  "sidebarPanels": ["info_selection", "visualization", "solve_seeds", "continuation", "optimization", "oscillator_analysis", "advanced_shooting_horizon"],
  "axisPresets": [
    {
      "id": "scientific_load",
      "label": "Load-pulling state view",
      "x": "quad_dx",
      "y": "quad_y",
      "z": "load_x",
      "dimension": "3-D",
      "azimuth": -37.5,
      "elevation": 30,
      "xLimits": [],
      "yLimits": [],
      "zLimits": []
    }
  ],
  "directionLabels": {
    "backward": "decreasing quadruped speed",
    "forward": "increasing quadruped speed"
  },
  "defaultSolveOptions": {
    "FunctionTolerance": 1e-10,
    "StepTolerance": 1e-10,
    "MaxIterations": 200,
    "MaxFunctionEvaluations": 2000,
    "Display": "off"
  },
  "defaultContinuationOptions": {
    "InitialStep": 0.02,
    "MinimumStep": 0.0001,
    "MaximumStep": 0.1,
    "MaximumPoints": 12,
    "CorrectorTolerance": 1e-9,
    "BothDirections": true,
    "RequireFeasible": true
  }
}
