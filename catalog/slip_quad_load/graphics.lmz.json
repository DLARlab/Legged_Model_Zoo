    "tutorial": "clean_generic",
    "compatibility": "clean_generic",
    "validated": "research_legacy",
    "experimental": "clean_generic"
  },
  "requiredFrames": ["world", "quadruped_center_of_mass", "load_center", "ground_contact"],
  "requiredParameters": ["per_stride_parameters", "quadruped", "load"],
