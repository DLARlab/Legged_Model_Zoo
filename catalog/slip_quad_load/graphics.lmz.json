        "followWindow": [-3.0, 1.5]
      },
      "axis": {
        "equal": false,
        "grid": false,
        "visible": false,
        "title": "SLIP Quad-Load Animation",
        "backgroundColor": [1, 1, 1]
      },
      "layers": ["ground", "legs", "body", "com", "load", "rope"],
      "overlays": [],
      "plotProfile": "research_legacy",
      "recordingProfile": {"frameCount": 120, "fps": 20, "dpi": 120, "backgroundColor": [1, 1, 1]},
      "maturities": ["validated"]
    },
    {
      "id": "clean_generic",
      "label": "Clean generic",
