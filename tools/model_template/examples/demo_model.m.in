projectRoot = fileparts(fileparts(mfilename('fullpath')));
registry = lmz.registry.ModelRegistry.discoverWithPlugins( ...
    projectRoot, 'IncludeBuiltIns', false);
model = registry.createModel('{{MODEL_ID}}');
problem = model.createProblem('periodic_orbit', struct());
output = problem.evaluate(problem.getDecisionSchema().defaults(), ...
    problem.getParameterSchema().defaults(), ...
    lmz.api.RunContext.synchronous(0), true);
fprintf('LMZ_GENERATED_MODEL_OK id={{MODEL_ID}} residual=%.3g\n', ...
    output.ScaledResidualNorm);
